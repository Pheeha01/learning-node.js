// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  company_id            Int       @id @default(autoincrement())
  company_name          String
  registration_number   String @unique
  business_type         String
  number_of_employees   Int?
  year_established      Int?
  company_description   String?
  created_at            DateTime  @default(now())

  industry              Industry? @relation(fields: [industry_id], references: [industry_id])
  industry_id           Int?

  location              Location? @relation(fields: [location_id], references: [location_id])
  location_id           Int?

  products              CompanyProducts[]
  regions               CompanyRegions[]
  targets               CompanyTargets[] @relation("SourceCompany")
  target_of             CompanyTargets[] @relation("TargetCompany")
  matches               CompanyMatches[] @relation("Company1")
  matched_with          CompanyMatches[] @relation("Company2")
}
model Industry {
  industry_id Int @id @default(autoincrement())
  industry_name String @unique
  companies Company[]
}
model Location {
  location_id Int @id @default(autoincrement())
  country String
  companies Company[]
}
model Product {
  product_id Int @id @default(autoincrement())
  product_name String @unique
  companies CompanyProducts[]
}
model CompanyProducts {
  company_id Int
  product_id Int
  company Company @relation(fields: [company_id], references: [company_id])
  product Product @relation(fields: [product_id], references: [product_id])
  @@id([company_id, product_id])
}
model Region {
  region_id Int @id @default(autoincrement())
  region_name String @unique
  companies CompanyRegions[]
}
model CompanyRegions {
  company_id Int
  region_id Int
  company Company @relation(fields: [company_id], references: [company_id])
  region Region @relation(fields: [region_id], references: [region_id])
  @@id([company_id, region_id])
}
model CompanyTargets {
  source_company_id Int
  target_company_id Int
  status String? @default("pending")
  notes String?
  created_at DateTime @default(now())
  source Company @relation("SourceCompany", fields: [source_company_id], references: [company_id])
  target Company @relation("TargetCompany", fields: [target_company_id], references: [company_id])
  @@id([source_company_id, target_company_id])
}
model CompanyMatches {
  company1_id Int
  company2_id Int
  matched_at DateTime @default(now())
  match_type String?
  company1 Company @relation("Company1", fields: [company1_id], references: [company_id])
  company2 Company @relation("Company2", fields: [company2_id], references: [company_id])
  @@id([company1_id, company2_id])
}



